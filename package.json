{
  "name": "folex-lite-astro",
  "type": "module",
  "version": "3.0.0",
  "description": "A highly customizable creative agency & personal portfolio business theme built with Tailwind CSS and Astro Js",
  "author": "getastrothemes",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "keywords": [
    "astro",
    "template",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/getastrothemes/folex-lite-astro.git"
  },
  "scripts": {
    "dev": "npm run toml:watch --watch & astro dev",
    "build": "npm run toml:watch && astro build && npm run remove-draft-from-sitemap",
    "preview": "astro build && npm run remove-draft-from-sitemap && astro preview",
    "astro-check": "astro check",
    "toml:watch": "node scripts/toml-watcher.mjs",
    "generate-favicons": "node ./scripts/generate-favicons.mjs",
    "remove-multilingual": "node ./scripts/remove-multilingual.mjs",
    "remove-draft-from-sitemap": "node ./scripts/remove-draft-from-sitemap.mjs",
    "format": "prettier -w ./src",
    "deploy:cf": "wrangler pages deploy"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.4",
    "@popperjs/core": "^2.11.8",
    "@preline/accordion": "^3.2.3",
    "@preline/collapse": "^3.2.3",
    "@preline/overlay": "^3.2.3",
    "@preline/select": "^3.2.3",
    "aos": "^2.3.4",
    "astro-swiper": "^2.2.1",
    "date-fns": "^4.1.0",
    "lucide": "^0.577.0",
    "marked": "^17.0.1",
    "preline": "^3.2.3",
    "smoothscroll-for-websites": "^1.5.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/sitemap": "^3.7.1",
    "@realfavicongenerator/generate-favicon": "^0.6.0",
    "@realfavicongenerator/image-adapter-node": "^0.6.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^6.0.2",
    "astro-font": "^1.1.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.0",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-toml": "^2.0.6",
    "rehype-external-links": "^3.0.0",
    "remark-toc": "^9.0.0",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.1.18",
    "toml": "^3.0.0",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "@taplo/lib": "0.4.0-alpha.2",
    "yaml-language-server": "^1.20.1",
    "lodash": ">=4.17.23",
    "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
    "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
    "svgo@=4.0.0": ">=4.0.1",
    "devalue@<=5.6.3": ">=5.6.4",
    "vite": "^7"
  }
}
